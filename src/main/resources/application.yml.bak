spring:
  application:
    name: url-shortener
  
  datasource:
    url: jdbc:postgresql://localhost:5432/urlshortener
    username: postgres
    password: admin123
    driver-class-name: org.postgresql.Driver
  
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        format_sql: true
  
  redis:
    host: localhost
    port: 6379

app:
  base-url: http://localhost:8080
  short-code-length: 7

server:
  port: 8080

logging:
  level:
    com.urlshortener: DEBUG